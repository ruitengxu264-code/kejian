. // --- Notebook code cell 5 ---
. capture program drop gen_panel

. program define gen_panel
  1.     syntax, [n(integer 500) t(integer 10) rho(real 0.8) te(real 0.0) seed(
> integer 0)]
  2.     clear
  3.     set seed `seed'
  4.     set obs `n'
  5.     gen unit = _n
  6.     gen unit_fe = rnormal(0, 1)
  7.     
.     * 随机选 1/5 的单位作为处理组
.     gen u = runiform()
  8.     sort u
  9.     gen treated = (_n <= `n' / 5)
 10.     drop u
 11.     
.     expand `t'
 12.     bysort unit: gen t = _n
 13.     
.     * 时间效应
.     sort t unit
 14.     by t: gen time_fe = rnormal(0, 0.5) if _n == 1
 15.     by t: replace time_fe = time_fe[1]
 16.     
.     * AR(1) 误差：eps_it = rho * eps_{i,t-1} + u_it
.     xtset unit t
 17.     gen eps = .
 18.     by unit (t): replace eps = rnormal(0, 1) if _n == 1
 19.     by unit (t): replace eps = `rho' * eps[_n-1] + rnormal(0, 1) if _n > 1
 20.     
.     * 处理指示与结果
.     gen D = (treated == 1 & t >= 5)
 21.     gen Y = unit_fe + time_fe + `te' * D + eps
 22. end

. 
