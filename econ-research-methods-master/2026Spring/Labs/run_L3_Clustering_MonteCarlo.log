. // --- Notebook code cell 9 ---
. postfile mcresults rep p_iid p_hc p_cl using mc_cluster.dta, replace

. 
. local nreps = 300

. forvalues r = 1/`nreps' {
  2.     quietly {
  3.         gen_panel, n(500) t(10) rho(0.8) te(0.0) seed(`r')
  4.         
.         reghdfe Y D, absorb(unit t)
  5.         local p_iid = 2 * ttail(e(df_r), abs(_b[D] / _se[D]))
  6.         
.         reghdfe Y D, absorb(unit t) vce(robust)
  7.         local p_hc = 2 * ttail(e(df_r), abs(_b[D] / _se[D]))
  8.         
.         reghdfe Y D, absorb(unit t) vce(cluster unit)
  9.         local p_cl = 2 * ttail(e(df_r), abs(_b[D] / _se[D]))
 10.     }
 11.     post mcresults (`r') (`p_iid') (`p_hc') (`p_cl')
 12.     if mod(`r', 50) == 0 display "完成 `r' / `nreps'"
 13. }
完成 50 / 300
完成 100 / 300
完成 150 / 300
完成 200 / 300
完成 250 / 300
完成 300 / 300

. postclose mcresults

. 
. use mc_cluster.dta, clear

. foreach se in iid hc cl {
  2.     gen reject_`se' = (p_`se' < 0.05)
  3.     quietly summarize reject_`se', meanonly
  4.     display "标准误类型 `se': 拒绝率 = " %5.1f r(mean) * 100 "%"
  5. }
标准误类型 iid: 拒绝率 =  28.7%
标准误类型 hc: 拒绝率 =  29.3%
标准误类型 cl: 拒绝率 =   6.3%

